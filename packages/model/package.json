{
  "name": "@verana-labs/vs-agent-model",
  "main": "build/index",
  "types": "build/index",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "require": "./build/index.js",
      "default": "./build/index.js"
    },
    "./ecs": {
      "types": "./build/utils/ecs.d.ts",
      "require": "./build/utils/ecs.js",
      "default": "./build/utils/ecs.js"
    }
  },
  "version": "1.10.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/verana-labs/vs-agent"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm run clean && pnpm run compile",
    "clean": "rimraf -rf ./build",
    "compile": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "version": "pnpm version --allow-same-version",
    "test": "vitest"
  },
  "dependencies": {
    "@2060.io/credo-ts-didcomm-reactions": "0.1.1",
    "@2060.io/credo-ts-didcomm-receipts": "0.1.1",
    "@credo-ts/core": "0.7.1-pr-2704-20260504205328",
    "@credo-ts/didcomm": "0.7.1-pr-2704-20260504205328",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  },
  "peerDependencies": {
    "@credo-ts/core": "0.7.1-pr-2704-20260504205328"
  }
}
