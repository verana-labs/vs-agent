{
  "name": "@verana-labs/vs-agent-sdk",
  "main": "build/index",
  "types": "build/index",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "require": "./build/index.js",
      "default": "./build/index.js"
    }
  },
  "version": "1.10.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/verana-labs/vs-agent"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "description": "Framework-agnostic Verifiable Service Agent SDK",
  "scripts": {
    "build": "pnpm run clean && pnpm run compile",
    "clean": "rimraf -rf ./build",
    "compile": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "version": "pnpm version --allow-same-version",
    "test": "vitest"
  },
  "dependencies": {
    "@cosmjs/proto-signing": "^0.32.3",
    "@cosmjs/stargate": "^0.32.3",
    "@cosmjs/tendermint-rpc": "^0.32.4",
    "@credo-ts/anoncreds": "0.7.0-alpha-20260410113934",
    "@credo-ts/askar": "0.7.0-alpha-20260410113934",
    "@credo-ts/core": "0.7.0-alpha-20260410113934",
    "@credo-ts/didcomm": "0.7.0-alpha-20260410113934",
    "@credo-ts/webvh": "0.7.0-alpha-20260410113934",
    "@hyperledger/anoncreds-nodejs": "^0.4.0",
    "@openwallet-foundation/askar-nodejs": "^0.6.0",
    "@verana-labs/verana-types": "0.10.1-dev.11",
    "@verana-labs/credo-ts-didcomm-vt-flow": "workspace:*",
    "@verana-labs/vs-agent-model": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axios": "^1.7.9",
    "credo-ts-didweb-anoncreds": "0.0.2-alpha.5",
    "didwebvh-ts": "^2.5.6",
    "express": "^4.18.1",
    "tsyringe": "4.8.0"
  },
  "peerDependencies": {
    "@credo-ts/core": "0.7.0-alpha-20260410113934",
    "@credo-ts/node": "0.7.0-alpha-20260410113934"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  }
}
