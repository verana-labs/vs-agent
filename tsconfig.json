{
  "extends": "./tsconfig.build.json",
  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "files": true
  },
  "compilerOptions": {
    "skipLibCheck": true,
    "paths": {
      "@verana-labs/*": ["./packages/*/src"]
    },
    "types": ["vitest", "node"]
  },
  "exclude": ["node_modules", "build", "examples", "apps/vs-agent-ui"]
}
