{
  "name": "vs-agent",
  "version": "1.11.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Verifiable Trust Agent SDK",
  "homepage": "https://verana.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/verana-labs/vs-agent"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --sort run build",
    "ui": "pnpm --filter @verana-labs/vs-agent-ui",
    "start": "pnpm ui build && pnpm --filter @verana-labs/vs-agent start",
    "start:dev": "pnpm ui build:watch & pnpm --filter @verana-labs/vs-agent start:dev",
    "start:chatbot": "pnpm --filter demo-chatbot start",
    "start:verifier": "pnpm --filter demo-verifier start",
    "start:nestjsvs": "pnpm --filter nestjs-vs start",
    "check-types": "pnpm -r --workspace-concurrency=1 exec tsc --noEmit",
    "fix-format": "biome format --write .",
    "check-format": "biome check .",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @verana-labs/vs-agent-sdk test:e2e",
    "lint": "biome lint --write .",
    "validate": "pnpm lint && pnpm check-types && pnpm check-format",
    "prepare": "corepack enable"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@types/node": "^20.11.19",
    "@types/supertest": "^2.0.12",
    "@vitest/coverage-v8": "^4.0.14",
    "rimraf": "^6.0.1",
    "supertest": "^6.2.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.1.0",
    "typescript": "^5.6.2",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">= 18"
  },
  "resolutions": {
    "@types/node": "20.11.19",
    "tsyringe": "4.8.0",
    "@hyperledger/anoncreds-nodejs": "0.4.0",
    "@hyperledger/anoncreds-shared": "0.4.0",
    "@credo-ts/action-menu": "0.7.1-pr-2704-20260630143332",
    "@credo-ts/core": "0.7.1-pr-2704-20260630143332",
    "@credo-ts/didcomm": "0.7.1-pr-2704-20260630143332",
    "@credo-ts/question-answer": "0.7.1-pr-2704-20260630143332",
    "@credo-ts/node": "0.7.1-pr-2704-20260630143332",
    "@credo-ts/askar": "0.7.1-pr-2704-20260630143332",
    "@credo-ts/anoncreds": "0.7.1-pr-2704-20260630143332"
  },
  "packageManager": "pnpm@9.15.3",
  "pnpm": {
    "overrides": {
      "libphonenumber-js": "^1.12.33",
      "@credo-ts/core": "0.7.1-pr-2704-20260630143332",
      "@credo-ts/didcomm": "0.7.1-pr-2704-20260630143332",
      "@credo-ts/anoncreds": "0.7.1-pr-2704-20260630143332",
      "@credo-ts/askar": "0.7.1-pr-2704-20260630143332",
      "@hyperledger/anoncreds-shared": "0.4.0"
    }
  }
}
